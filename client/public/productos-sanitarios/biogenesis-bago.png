				<script>
				function toggleRegSel(){
					if(document.querySelector("#regSel").style.display!="block"){
						document.querySelector("#regSel").style.display="block";
					}else{
						document.querySelector("#regSel").style.display="none";
					}
				}
				
				function toggleRegSel2(){
					console.log("rel sel 2");
					if(document.querySelector("#regSel.regSelMobile").style.display!="block"){
						document.querySelector("#regSel.regSelMobile").style.display="block";
					}else{
						document.querySelector("#regSel.regSelMobile").style.display="none";
					}
				}
				
				function closeLang(){
					document.querySelector("#regSel").style.display="none";
				}
				function closeLang2(){
					document.querySelector("#regSel.regSelMobile").style.display="none";
				}
				
				var langRegionInput=document.querySelector('[name="lang-region"]');
				
				
				function langSearch(){
					var toSearchLng=langRegionInput.value.toLowerCase();
					if(toSearchLng==""){
						toSearchLng= langRegionInput2.value.toLowerCase();
					}
					console.log(toSearchLng);
					document.querySelectorAll(".region span").forEach(function (userItem) {
						let itLang=userItem.textContent.trim().toLowerCase();
						console.log(itLang);
						if(itLang.indexOf(toSearchLng)>=0||toSearchLng==""){
							console.log("found!");
							userItem.parentNode.style.display="block";
						}else{
							userItem.parentNode.style.display="none";
						}
					});
					
					document.querySelectorAll(".region a").forEach(function (userItem) {
						// console.log(userItem);
						let itLang=userItem.textContent.trim().toLowerCase();
						
						if(userItem.parentNode.style.display=='block' || itLang.indexOf(toSearchLng)>=0||toSearchLng==""){
							console.log("found! "+itLang);
							//userItem.parentNode.style.display="block";
							userItem.style.display="inline-block";
						}else{
							userItem.style.display="none";
						}
						 
					});
					
					document.querySelectorAll(".region a").forEach(function (userItem) {
						if(userItem.style.display=='inline-block'){
							userItem.parentNode.style.display="block";
						}
					});
				}
				</script>
								
