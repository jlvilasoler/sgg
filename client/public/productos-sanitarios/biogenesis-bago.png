<script>
var playerYT;

var iframeYT;

var ytRedyExec=false;

function onYouTubeIframeAPIReady(){
	bagoOnYouTubeIframeAPIReady();
}

function ytChecker(){
	if(YT&& YT.loaded==1){
		bagoOnYouTubeIframeAPIReady();
	}else{
		if(!ytRedyExec){
			setTimeout(ytChecker,500);
		}
	}
}
setTimeout(ytChecker,500);

var videoId="t4nSUn6dI20";

function bagoOnYouTubeIframeAPIReady() {
	if(ytRedyExec){
		return;
	}
	console.log("execute video");
	ytRedyExec=true;
    playerYT = new YT.Player('video-yt-bago', {
        width: 672,
        height: 378,
        videoId: videoId,
        playerVars: {
            color: 'white',
            playlist: videoId,
						mute:1,
						autoplay:1,
						modestbranding:1,
						controls:0,
						showinfo:0,
						loop:1,
						rel:0
        },
        events: {
            onReady: initialize
        }
    });
}

function initialize(){

    iframeYT= document.querySelector("#newVideoHome iframe");
iframeYT.addEventListener('fullscreenchange', exitHandler, false);
 iframeYT.addEventListener('mozfullscreenchange', exitHandler, false);
 iframeYT.addEventListener('MSFullscreenChange', exitHandler, false);
 iframeYT.addEventListener('webkitfullscreenchange', exitHandler, false);
 jQuery("#about-us").on("click",function(){
	 fullScreenYT();
 });

}

function fullScreenYT(){

var requestFullScreen = iframeYT.requestFullScreen || iframeYT.mozRequestFullScreen || iframeYT.webkitRequestFullScreen;
  if (requestFullScreen) {
    requestFullScreen.bind(iframeYT)();
  }
	playerYT.unMute();
}


 

function exitHandler()
{
 if (!document.webkitIsFullScreen && !document.mozFullScreen && !document.msFullscreenElement)
 {
  playerYT.mute();
 }
}

</script>
			
