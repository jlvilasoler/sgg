NODE_ENV=development
PORT=3001
HOST=127.0.0.1

# Supabase → Project Settings → Database → Connection string
# Usar "Transaction pooler" (puerto 6543). El código agrega sslmode y pgbouncer automáticamente.
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Opcional: conexión directa (puerto 5432) para migraciones locales
# DATABASE_URL_DIRECT=postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres

SCG_CLIENT_ORIGIN=http://127.0.0.1:5173
SCG_TRUST_PROXY=0
SCG_ADMIN_EMAIL=jlvilasoler@gmail.com
SCG_ADMIN_PASSWORD=Admin123

# Vercel: configurar DATABASE_URL, SCG_ADMIN_EMAIL y SCG_ADMIN_PASSWORD en el dashboard.
# SCG_CLIENT_ORIGIN es opcional (se detecta VERCEL_URL automáticamente).
