NODE_ENV=development
PORT=3001
HOST=127.0.0.1

# Desarrollo local: misma base que producción (Supabase).
# Copiá DATABASE_URL desde Vercel → Settings → Environment Variables,
# o desde Supabase → Database → Connection string → Transaction pooler (6543).
# NO commitear server/.env (está en .gitignore).
DATABASE_URL=postgresql://postgres.mxcrpumaadtixlmnlgmj:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Opcional: SCG_DB_POOL_MAX=5  SCG_DB_SESSION=1 (forzar session pooler 5432, no recomendado)

SCG_CLIENT_ORIGIN=http://127.0.0.1:5173
SCG_TRUST_PROXY=0
SCG_ADMIN_EMAIL=jlvilasoler@gmail.com
SCG_ADMIN_PASSWORD=Admin123

# Producción (Render): disco persistente en /var/data (ver render.yaml).
# SCG_DATA_DIR=/var/data
# En Vercel las fotos de animales se guardan en Postgres (BYTEA), no en disco efímero.
# SCG_CLIENT_ORIGIN en Vercel es opcional (mismo dominio que /api se detecta solo).
# Si usás dominio custom, podés setear SCG_CLIENT_ORIGINS=https://tu-dominio.com,https://otro.vercel.app

# Recuperación de contraseña por email (elegí Resend O SMTP).
# Resend (recomendado en Vercel): https://resend.com
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=SAG <noreply@tudominio.com>

# SMTP alternativo (Gmail, Brevo, SendGrid, etc.)
# SMTP_HOST=smtp.ejemplo.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=usuario
# SMTP_PASS=contraseña
# SMTP_FROM=SAG <noreply@tudominio.com>
