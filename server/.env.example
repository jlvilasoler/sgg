NODE_ENV=development
PORT=3001
HOST=127.0.0.1

# Desarrollo local: misma base que producción (Supabase).
# Copiá DATABASE_URL desde Vercel → Settings → Environment Variables,
# o desde Supabase → Database → Connection string → Transaction pooler (6543).
# NO commitear server/.env (está en .gitignore).
DATABASE_URL=postgresql://postgres.mxcrpumaadtixlmnlgmj:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Opcional: SCG_DB_POOL_MAX=5  SCG_DB_SESSION=1 (forzar session pooler 5432, no recomendado)

SCG_CLIENT_ORIGIN=http://127.0.0.1:5173
SCG_TRUST_PROXY=0
SCG_ADMIN_EMAIL=jlvilasoler@gmail.com
SCG_ADMIN_PASSWORD=Admin123

# Producción (Render): disco persistente en /var/data (ver render.yaml).
# SCG_DATA_DIR=/var/data
# En Vercel las fotos de animales se guardan en Postgres (BYTEA), no en disco efímero.
# SCG_CLIENT_ORIGIN en Vercel es opcional (mismo dominio que /api se detecta solo).
# Si usás dominio custom, podés setear SCG_CLIENT_ORIGINS=https://tu-dominio.com,https://otro.vercel.app

# Recuperación de contraseña por email (elegí Resend O SMTP).
#
# --- Opción A: Resend (recomendado en Vercel) ---
# 1. Creá cuenta en https://resend.com (plan gratis: ~100 emails/día).
# 2. API Keys → Create API Key → copiá la clave (empieza con re_).
# 3. En Vercel → tu proyecto → Settings → Environment Variables (Production):
#      RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
#      EMAIL_FROM=SAG <noreply@tudominio.com>
#    Redeploy después de guardar.
#
# Prueba rápida SIN dominio propio (solo para validar que funciona):
#   EMAIL_FROM=SAG <onboarding@resend.dev>
#   Resend solo entrega a la dirección con la que te registraste en Resend.
#   Útil para probar forgot-password en producción antes de verificar dominio.
#
# Producción real (usuarios de cualquier email):
#   Resend → Domains → Add Domain → agregá los registros DNS (SPF + DKIM).
#   Cuando figure "Verified", usá un remitente de ese dominio:
#   EMAIL_FROM=SAG <noreply@tudominio.com>
#
# Enlace del email de recuperación: el servidor usa VERCEL_URL automáticamente.
# Si tenés dominio custom, agregá también:
# SCG_CLIENT_ORIGINS=https://tudominio.com,https://tu-proyecto.vercel.app
#
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=SAG <noreply@tudominio.com>
#
# --- Opción B: Gmail (desarrollo o cuentas pequeñas) ---
# 1. Activá verificación en 2 pasos en tu cuenta Google
# 2. Creá una "Contraseña de aplicación" en Seguridad de Google
# 3. Descomentá y completá:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=tu@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM=SAG <tu@gmail.com>
#
# Sin Resend ni SMTP, en desarrollo el enlace de recuperación aparece en pantalla
# y en la consola del servidor al solicitar "¿Olvidaste tu contraseña?".

# --- Suscripciones Mercado Pago (modo test, sin cobros reales) ---
# 1. Creá una aplicación en https://www.mercadopago.com.uy/developers
# 2. En Credenciales de prueba copiá Access Token y Public Key (prefijo TEST-)
# 3. En Webhooks (opcional en local) apuntá a https://tu-tunel/api/billing/mercadopago/webhook
# MP_ACCESS_TOKEN=TEST-xxxxxxxx
# MP_PUBLIC_KEY=TEST-xxxxxxxx
# BILLING_SANDBOX=1
# BILLING_TRIAL_DAYS=14
